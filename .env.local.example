# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Admin Dashboard ────────────────────────────────────────────────────────────
# Password for logging into /admin
ADMIN_PASSWORD=choose-a-strong-password

# ── Resend (Email) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Your Org Name <admin@yourdomain.com>

# ── M-Pesa Daraja API ──────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_BUSINESS_SHORT_CODE=your-shortcode
MPESA_PASSKEY=your-passkey
# Must be a publicly accessible HTTPS URL (use ngrok for local dev)
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa-callback
# Use 'sandbox' for testing, 'production' to go live
MPESA_ENVIRONMENT=sandbox
